# Deployment
COMPOSE_PROJECT_NAME=mediaclaw
IMAGE_TAG=latest
APP_DOMAIN=api.example.com
NODE_ENV=production
API_HOST_PORT=3002
WORKER_HOST_PORT=3003
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MIGRATION_CMD=

# MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=mediaclaw
MONGODB_PASSWORD=change-me
MONGODB_DB_NAME=aitoearn

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-or-keep-existing-production-secret

# Authentication
JWT_SECRET=change-me-or-keep-existing-production-jwt-secret
INTERNAL_TOKEN=change-me

# AI and Assets
AI_URL=http://host.docker.internal:3010
ASSETS_CONFIG={"provider":"s3","bucketName":"mediaclaw-assets","endpoint":"http://host.docker.internal:9000","publicEndpoint":"http://api.example.com:9000","accessKey":"replace-me","secretKey":"replace-me","region":"auto","forcePathStyle":true}
MEDIACLAW_PLATFORM_ACCOUNT_SECRET=change-me
MEDIACLAW_HEAP_HEALTH_LIMIT_MB=768

# RustFS
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_SERVER_DOMAINS=
RUSTFS_S3_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# Mail and SMS
MAIL_USER=
MAIL_PASS=
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
ALI_SMS_SIGN_NAME=
ALI_SMS_TEMPLATE_CODE=

# Payment and callback
XORPAY_API_URL=
XORPAY_CREATE_ORDER_URL=
XORPAY_APP_ID=
XORPAY_NOTIFY_URL=https://api.example.com/api/v1/payment/callback
XORPAY_RETURN_URL=https://api.example.com/payment/return
XORPAY_SECRET=
XORPAY_MD5_KEY=

# Relay and crawler
RELAY_SERVER_URL=
RELAY_API_KEY=
RELAY_CALLBACK_URL=
TIKHUB_BASE_URL=
TIKHUB_API_KEY=

# Monitoring
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=30d
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
ALERTMANAGER_PORT=9093
WECOM_WEBHOOK_URL=

# Backup
BACKUP_ROOT=/var/backups/mediaclaw
BACKUP_BUCKET_URL=s3://mediaclaw-backups/production
BACKUP_MONGODB_URI=mongodb://mediaclaw:change-me@mongodb:27017/?authSource=admin&directConnection=true
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
AWS_REGION=ap-southeast-1
OSSUTIL_CONFIG_FILE=

# Runtime resources
API_MEM_LIMIT=768m
API_CPUS=1.50
WORKER_MEM_LIMIT=768m
WORKER_CPUS=1.50
MONGODB_MEM_LIMIT=512m
MONGODB_CPUS=1.00
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.50
RUSTFS_MEM_LIMIT=1024m
RUSTFS_CPUS=1.00
NGINX_MEM_LIMIT=128m
NGINX_CPUS=0.50

# Third-party OAuth
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KWAI_CLIENT_ID=
KWAI_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_TEST_AUTHORIZATION=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
WXPLAT_APP_ID=
WXPLAT_APP_SECRET=
WXPLAT_ENCODING_AES_KEY=
DOYIN_CLIENT_ID=
DOYIN_CLIENT_SECRET=
