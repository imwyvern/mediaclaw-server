# ===== MediaClaw Environment Config =====

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mediaclaw

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / RustFS compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=mediaclaw
MINIO_SECRET_KEY=mediaclaw123
MINIO_BUCKET=mediaclaw-assets

# JWT Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# API Server
API_PORT=3002
API_PREFIX=/api/v1

# XorPay Payment
XORPAY_AID=your-xorpay-aid
XORPAY_SECRET=your-xorpay-secret
XORPAY_CALLBACK_URL=https://api.mediaclaw.ai/api/v1/payment/callback

# VCE (Video Creation Engine) API
VCE_API_KEY=your-vce-api-key
VCE_BASE_URL=https://api.vectorengine.ai

# DeepSeek (Copy Engine)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# TikHub (Data Acquisition)
TIKHUB_API_KEY=your-tikhub-api-key
TIKHUB_BASE_URL=https://api.tikhub.io

# MediaCrawlerPro (Deep Crawling)
MEDIACRAWLER_URL=http://localhost:8888

# Gemini (Frame Editing)
GEMINI_API_KEY=your-gemini-api-key

# SMS Provider (for phone login)
SMS_ACCESS_KEY=your-sms-access-key
SMS_ACCESS_SECRET=your-sms-access-secret
SMS_SIGN_NAME=MediaClaw
SMS_TEMPLATE_CODE=your-template-code

# ClawHost (V2)
CLAWHOST_API_URL=http://localhost:8080
CLAWHOST_API_KEY=your-clawhost-api-key

# Environment
NODE_ENV=development
